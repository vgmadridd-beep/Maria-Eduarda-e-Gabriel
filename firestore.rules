rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Gifts Collection
    match /gifts/{giftId} {
      allow read: if true; // Publicly readable for guest list
      
      // Validation helper for Gift
      function isValidGift(data) {
        return data.keys().hasAll(['number', 'name', 'description', 'priceRange', 'status'])
          && data.number is number
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.description is string && data.description.size() <= 500
          && data.priceRange is string && data.priceRange.size() <= 50
          && data.status in ['available', 'reserved'];
      }

      // Update gift: Reserve or Reset
      allow update: if (
        isValidId(giftId) &&
        isValidGift(incoming()) &&
        (
          // Action: Reserve
          (existing().status == "available" &&
          incoming().status == "reserved" &&
          incoming().reservedBy is string && incoming().reservedBy.size() > 0 && 
          incoming().reservedBy.size() <= 100 &&
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'reservedBy', 'updatedAt']))
          ||
          // Action: Reset (Disponibilizar)
          (existing().status == "reserved" &&
          incoming().status == "available" &&
          incoming().keys().size() == existing().keys().size() - 1 && // reservedBy removed
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'reservedBy', 'updatedAt']))
          ||
          // Generic update (might be needed for some clients or if we add more)
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'reservedBy', 'updatedAt']))
        )
      );

      // Setup/Admin
      allow create: if isValidId(giftId) && isValidGift(incoming());
    }

    // Messages Collection
    match /messages/{messageId} {
      allow read, write: if true; // Publicly readable mural, unrestricted write for now
    }

    // RSVP Collection
    match /rsvp/{rsvpId} {
      allow read, get, list: if true;
      allow create, update, delete: if true;
    }
  }
}
